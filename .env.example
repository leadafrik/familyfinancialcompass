FFC_ENV=development
FFC_HOST=0.0.0.0
FFC_PORT=8000
FFC_SCENARIO_STORE_BACKEND=postgres
FFC_DATA_DIR=data
FFC_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
FFC_DB_MAX_POOL_SIZE=10
FFC_DB_CONNECT_TIMEOUT_SECONDS=5.0
FFC_ASSUMPTIONS_PATH=config/system_assumptions.json
FFC_DEFAULT_USER_ID=anonymous
FFC_SCENARIO_LIST_DEFAULT_LIMIT=25
FFC_SCENARIO_LIST_MAX_LIMIT=100
FFC_ALLOWED_ORIGINS=http://localhost:5173
FFC_API_KEY=replace-with-a-strong-random-secret

# Optional
# GROQ_API_KEY=replace-with-your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_BASE_URL=https://api.groq.com/openai/v1/chat/completions
# BLS_API_KEY=replace-with-your-bls-key
